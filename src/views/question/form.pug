extends ../layouts/main

block content
  .row
    .col-md-8.mx-auto
      .card
        .card-header
          h3= question ? 'Edit Question' : 'Create Question'
        .card-body
          form(method="POST" action=question ? `/questions/${question.id}/edit` : '/questions/create' enctype="multipart/form-data")
            .mb-3
              label.form-label(for="text") Question Text
              textarea.form-control#text(name="text" rows="3" required)= question ? question.text : ''
            .row
              .col-md-4.mb-3
                label.form-label(for="contentType") Content Type
                select.form-select#contentType(name="contentType")
                  option(value="text" selected=(question && question.content_type === 'text')) Text Only
                  option(value="image" selected=(question && question.content_type === 'image')) Image
                  option(value="audio" selected=(question && question.content_type === 'audio')) Audio
                  option(value="video" selected=(question && question.content_type === 'video')) Video
              .col-md-4.mb-3
                label.form-label(for="answerType") Answer Type
                select.form-select#answerType(name="answerType" onchange="toggleOptions()")
                  option(value="multiple_choice" selected=(question && question.answer_type === 'multiple_choice')) Multiple Choice
                  option(value="freeform_text" selected=(question && question.answer_type === 'freeform_text')) Freeform Text
                  option(value="drawing" selected=(question && question.answer_type === 'drawing')) Drawing
              .col-md-4.mb-3
                label.form-label(for="difficulty") Difficulty
                select.form-select#difficulty(name="difficulty")
                  option(value="easy" selected=(question && question.difficulty === 'easy')) Easy
                  option(value="medium" selected=(question && question.difficulty === 'medium')) Medium
                  option(value="hard" selected=(question && question.difficulty === 'hard')) Hard
            .mb-3
              label.form-label(for="media") Media File
              input.form-control#media(type="file" name="media" accept="image/*,audio/*,video/*")
              if question && question.media_path
                small.text-muted Current: #{question.media_path}
            .mb-3
              label.form-label(for="correctAnswer") Correct Answer
              input.form-control#correctAnswer(type="text" name="correctAnswer" value=(question ? question.correct_answer : ''))
            #optionsContainer.mb-3
              label.form-label Multiple Choice Options
              #optionFields
                if question && question.options && question.options.length
                  each opt, idx in question.options
                    .input-group.mb-2
                      input.form-control(type="text" name=`option_${idx + 1}` value=opt placeholder=`Option ${idx + 1}`)
                      button.btn.btn-outline-danger(type="button" onclick="removeOption(this)") &times;
                else
                  - for (var i = 1; i <= 4; i++)
                    .input-group.mb-2
                      input.form-control(type="text" name=`option_${i}` placeholder=`Option ${i}`)
                      button.btn.btn-outline-danger(type="button" onclick="removeOption(this)") &times;
              button.btn.btn-sm.btn-outline-secondary.mt-1(type="button" onclick="addOption()") + Add Option
            .mb-3
              label.form-label Tags
              - var tagInputId = 'questionTags'
              - var tagInputName = 'tags'
              - var existingTags = tags || []
              include ../partials/tagInput
            .mb-3
              label.form-label(for="timeLimit") Time Limit (seconds, 0 = manual advance)
              input.form-control#timeLimit(type="number" name="timeLimit" min="0" value=(question ? question.time_limit : 0))
            button.btn.btn-primary(type="submit")= question ? 'Update' : 'Create'

block scripts
  script(src="/js/tag-input.js")
  script.
    var optionCounter = document.querySelectorAll('#optionFields .input-group').length;

    function addOption() {
      optionCounter++;
      var div = document.createElement('div');
      div.className = 'input-group mb-2';
      div.innerHTML = '<input class="form-control" type="text" name="option_' + optionCounter + '" placeholder="Option ' + optionCounter + '">' +
        '<button class="btn btn-outline-danger" type="button" onclick="removeOption(this)">&times;</button>';
      document.getElementById('optionFields').appendChild(div);
    }

    function removeOption(btn) {
      btn.closest('.input-group').remove();
    }

    function toggleOptions() {
      var answerType = document.getElementById('answerType').value;
      var container = document.getElementById('optionsContainer');
      container.style.display = answerType === 'multiple_choice' ? 'block' : 'none';
    }

    toggleOptions();
    initTagInput('questionTags', '/api/tags');
