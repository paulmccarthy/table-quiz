extends ../layouts/main

block content
  .row.justify-content-center
    .col-md-6
      .card
        .card-header
          h3 Join: #{quiz.title}
        .card-body
          if user
            p You are logged in as #{user.display_name || user.email}.
            form(method="POST" action=`/quiz/join/${quiz.invite_token}`)
              button.btn.btn-primary.w-100(type="submit") Join Quiz
          else
            p Please log in or register to join this quiz.
            .d-grid.gap-2
              a.btn.btn-primary(href="/auth/login") Login
              a.btn.btn-outline-primary(href="/auth/register") Register
