.drawing-tools.mb-2
  .btn-group.btn-group-sm
    button.btn.btn-outline-dark.active#brushBtn(type="button") Brush
    button.btn.btn-outline-dark#eraserBtn(type="button") Eraser
  .d-inline-block.ms-2
    label.form-label.mb-0.me-1(for="brushSize") Size:
    input#brushSize(type="range" min="1" max="20" value="3" style="width:80px;vertical-align:middle")
  .d-inline-block.ms-2
    label.form-label.mb-0.me-1(for="brushColor") Color:
    input#brushColor(type="color" value="#000000" style="width:30px;height:30px;vertical-align:middle")
  button.btn.btn-sm.btn-outline-danger.ms-2#clearCanvas(type="button") Clear
canvas#drawingCanvas(width="600" height="400" style="border:1px solid #ccc;cursor:crosshair;max-width:100%")
