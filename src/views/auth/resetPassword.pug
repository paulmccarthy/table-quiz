extends ../layouts/main

block content
  .row.justify-content-center
    .col-md-6
      .card
        .card-header
          h3 Reset Password
        .card-body
          if token
            form(method="POST" action=`/auth/reset-password/${token}`)
              .mb-3
                label.form-label(for="password") New Password
                input.form-control#password(type="password" name="password" minlength="8" required)
              button.btn.btn-primary.w-100(type="submit") Reset Password
          else
            form(method="POST" action="/auth/reset-password")
              .mb-3
                label.form-label(for="email") Email
                input.form-control#email(type="email" name="email" required)
              button.btn.btn-primary.w-100(type="submit") Send Reset Link
